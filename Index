<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>منصة الصيدليات</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=IBM+Plex+Sans+Arabic:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<style>
  :root{
    --teal-950:#0A2E2C;
    --teal-800:#0F5257;
    --teal-600:#166B6E;
    --amber-500:#D9A441;
    --amber-300:#EFCB84;
    --paper:#F6F4EF;
    --surface:#FFFFFF;
    --ink:#1C2B2A;
    --ink-soft:#5B6B69;
    --line:#E4E0D6;
    --danger:#B3452C;
    --ok:#3D7A5C;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    font-family:'Tajawal', sans-serif;
    background:var(--paper);
    color:var(--ink);
    min-height:100vh;
  }
  .num{font-family:'IBM Plex Sans Arabic', sans-serif; font-variant-numeric: tabular-nums;}

  /* Shell */
  .shell{ display:flex; min-height:100vh; }
  .nav{
    width:260px; background:var(--teal-950); color:#EDEDE6;
    display:flex; flex-direction:column; flex-shrink:0;
  }
  .nav-brand{
    padding:28px 24px 20px; border-bottom:1px solid rgba(255,255,255,.08);
  }
  .nav-brand .mark{
    width:40px;height:40px;border-radius:10px;background:var(--amber-500);
    display:flex;align-items:center;justify-content:center;font-weight:900;color:var(--teal-950);
    font-size:18px; margin-bottom:10px;
  }
  .nav-brand h1{font-size:17px; font-weight:700;}
  .nav-brand p{font-size:12px; color:#9FB3B0; margin-top:2px;}
  .nav-mode{ padding:14px 24px 4px; font-size:11px; color:#7E948F; letter-spacing:.5px;}
  .nav-items{ padding:6px 14px; display:flex; flex-direction:column; gap:2px; flex:1;}
  .nav-item{
    display:flex; align-items:center; gap:10px; padding:11px 14px; border-radius:9px;
    color:#C7D2CF; font-size:14px; cursor:pointer; border:none; background:transparent;
    text-align:right; width:100%; font-family:inherit; transition:.15s;
  }
  .nav-item:hover{ background:rgba(255,255,255,.06); color:#fff;}
  .nav-item.active{ background:var(--teal-800); color:#fff; font-weight:600;}
  .nav-item .ico{ width:8px;height:8px;border-radius:50%; background:currentColor; opacity:.5; flex-shrink:0;}
  .nav-item.active .ico{ background:var(--amber-500); opacity:1;}
  .nav-foot{ padding:16px 24px; border-top:1px solid rgba(255,255,255,.08); font-size:12px; color:#7E948F;}

  .main{ flex:1; display:flex; flex-direction:column; min-width:0; }
  .topbar{
    height:64px; background:var(--surface); border-bottom:1px solid var(--line);
    display:flex; align-items:center; justify-content:space-between; padding:0 28px; flex-shrink:0;
  }
  .topbar h2{ font-size:16px; font-weight:700; }
  .topbar .who{ display:flex; align-items:center; gap:10px; font-size:13px; color:var(--ink-soft);}
  .avatar{ width:32px;height:32px;border-radius:50%; background:var(--amber-300); display:flex;align-items:center;justify-content:center; font-weight:700; color:var(--teal-950); font-size:13px;}

  .content{ padding:28px; overflow-y:auto; flex:1;}
  .screen{ display:none; animation:fade .25s ease; }
  .screen.active{ display:block; }
  @keyframes fade{ from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:none;} }

  /* Cards / generic */
  .grid{ display:grid; gap:16px; }
  .g4{ grid-template-columns:repeat(4,1fr);}
  .g3{ grid-template-columns:repeat(3,1fr);}
  .g2{ grid-template-columns:2fr 1fr;}
  .card{ background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:20px;}
  .stat-label{ font-size:12px; color:var(--ink-soft); margin-bottom:8px;}
  .stat-value{ font-size:26px; font-weight:900;}
  .stat-sub{ font-size:12px; color:var(--ok); margin-top:6px;}
  .stat-sub.warn{ color:var(--danger); }

  h3.section-title{ font-size:15px; font-weight:700; margin-bottom:14px; }

  table{ width:100%; border-collapse:collapse; font-size:13px;}
  th{ text-align:right; color:var(--ink-soft); font-weight:600; padding:9px 10px; border-bottom:1px solid var(--line); font-size:12px;}
  td{ padding:11px 10px; border-bottom:1px solid var(--line); }
  tr:last-child td{ border-bottom:none; }
  .pill{ display:inline-block; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;}
  .pill.ok{ background:#E4F0E9; color:var(--ok);}
  .pill.pending{ background:#FBF0DA; color:#96701C;}
  .pill.danger{ background:#F7E4DE; color:var(--danger);}

  .btn{ border:none; border-radius:9px; padding:10px 18px; font-family:inherit; font-weight:700; font-size:13px; cursor:pointer;}
  .btn-primary{ background:var(--teal-800); color:#fff; }
  .btn-primary:hover{ background:var(--teal-600); }
  .btn-amber{ background:var(--amber-500); color:var(--teal-950); }
  .btn-ghost{ background:transparent; border:1px solid var(--line); color:var(--ink); }

  /* Login screen */
  .login-wrap{ min-height:100vh; display:flex; align-items:center; justify-content:center; background:linear-gradient(160deg,var(--teal-950),var(--teal-800)); }
  .login-box{ background:var(--surface); width:380px; border-radius:18px; padding:36px 32px; box-shadow:0 20px 60px rgba(0,0,0,.3);}
  .login-box .mark{ width:46px;height:46px;border-radius:12px;background:var(--amber-500); display:flex;align-items:center;justify-content:center;font-weight:900;color:var(--teal-950); font-size:20px; margin-bottom:16px;}
  .login-box h1{ font-size:20px; margin-bottom:4px;}
  .login-box p{ font-size:13px; color:var(--ink-soft); margin-bottom:26px;}
  .field{ margin-bottom:16px; }
  .field label{ display:block; font-size:12px; font-weight:600; margin-bottom:6px; color:var(--ink-soft);}
  .field input, .field select{ width:100%; padding:11px 12px; border:1px solid var(--line); border-radius:9px; font-family:inherit; font-size:14px; background:#FBFAF7;}
  .field input:focus, .field select:focus{ outline:2px solid var(--amber-300); border-color:var(--amber-500);}
  .login-box .btn-primary{ width:100%; padding:12px; margin-top:6px; font-size:14px;}
  .back-link{ text-align:center; margin-top:16px; font-size:12px; color:#EFCB84; cursor:pointer;}

  /* Product grid */
  .toolbar{ display:flex; gap:10px; margin-bottom:18px; }
  .toolbar input{ flex:1; padding:11px 14px; border:1px solid var(--line); border-radius:9px; font-family:inherit; background:var(--surface);}
  .toolbar select{ padding:11px 14px; border:1px solid var(--line); border-radius:9px; font-family:inherit; background:var(--surface);}
  .p-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
  .p-card{ background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px; display:flex; flex-direction:column; gap:8px;}
  .p-top{ display:flex; justify-content:space-between; align-items:flex-start;}
  .p-name{ font-weight:700; font-size:14px;}
  .p-sub{ font-size:11px; color:var(--ink-soft);}
  .p-exp{ font-size:11px; margin-top:2px;}
  .p-bottom{ display:flex; justify-content:space-between; align-items:center; margin-top:6px;}
  .p-price{ font-weight:900; font-size:15px;}
  .add-btn{ background:var(--teal-800); color:#fff; border:none; border-radius:8px; width:32px;height:32px; font-size:18px; cursor:pointer;}
  .add-btn:hover{ background:var(--teal-600); }

  /* Cart */
  .cart-item{ display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--line);}
  .cart-item:last-child{ border-bottom:none;}
  .cart-name{ font-weight:600; font-size:13px;}
  .cart-meta{ font-size:11px; color:var(--ink-soft);}
  .qty{ display:flex; align-items:center; gap:8px;}
  .qty button{ width:24px;height:24px; border-radius:6px; border:1px solid var(--line); background:#fff; cursor:pointer;}
  .pay-opt{ display:flex; gap:10px; margin-top:10px;}
  .pay-opt label{ flex:1; border:1px solid var(--line); border-radius:10px; padding:12px; text-align:center; font-size:12px; cursor:pointer; font-weight:600;}
  .pay-opt input{ display:none; }
  .pay-opt input:checked + span{ color:var(--teal-800); }
  .pay-opt label:has(input:checked){ border-color:var(--teal-800); background:#EAF3F1;}
  .summary-row{ display:flex; justify-content:space-between; font-size:13px; padding:6px 0; color:var(--ink-soft);}
  .summary-row.total{ color:var(--ink); font-weight:800; font-size:16px; border-top:1px solid var(--line); margin-top:8px; padding-top:12px;}

  /* Product thumbnail */
  .prod-thumb{
    width:38px; height:38px; border-radius:8px; background:#EAF3F1; border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center; font-size:18px; overflow:hidden;
  }
  .prod-thumb img{ width:100%; height:100%; object-fit:cover; }

  /* Modal */
  .modal-overlay{
    display:none; position:fixed; inset:0; background:rgba(10,46,44,.45);
    align-items:center; justify-content:center; z-index:50; padding:20px;
  }
  .modal-overlay.open{ display:flex; }
  .modal-box{
    background:var(--surface); border-radius:16px; width:480px; max-width:100%;
    max-height:90vh; overflow-y:auto; box-shadow:0 24px 70px rgba(0,0,0,.35);
  }
  .modal-head{
    display:flex; justify-content:space-between; align-items:center;
    padding:18px 22px; border-bottom:1px solid var(--line);
  }
  .modal-head h3{ font-size:16px; font-weight:700; }
  .modal-close{ background:none; border:none; font-size:22px; color:var(--ink-soft); cursor:pointer; line-height:1;}
  .modal-body{ padding:22px; }
  .modal-foot{
    display:flex; justify-content:flex-end; gap:10px;
    padding:16px 22px; border-top:1px solid var(--line);
  }

  .img-upload{
    border:2px dashed var(--line); border-radius:12px; height:160px;
    display:flex; align-items:center; justify-content:center; cursor:pointer;
    background:#FBFAF7; transition:.15s; overflow:hidden; position:relative;
  }
  .img-upload:hover{ border-color:var(--amber-500); background:#FBF6EA; }
  .img-upload img{ width:100%; height:100%; object-fit:cover; }
  .img-upload-ico{ font-size:26px; margin-bottom:6px; }
  .img-upload-text{ font-size:13px; font-weight:600; color:var(--ink); }
  .img-upload-hint{ font-size:11px; color:var(--ink-soft); margin-top:2px; }
  #imgPlaceholder{ text-align:center; }
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="loginScreen" class="login-wrap">
  <div class="login-box">
    <div class="mark">ص</div>
    <h1>دخول المنصة</h1>
    <p>سجّل دخولك لتصفح المنتجات ومتابعة طلباتك</p>
    <div class="field">
      <label>البريد الإلكتروني</label>
      <input type="email" id="loginEmail" placeholder="pharmacy@example.com">
    </div>
    <div class="field">
      <label>كلمة المرور</label>
      <input type="password" id="loginPassword" placeholder="••••••••">
    </div>
    <div id="loginError" style="display:none; color:var(--danger); font-size:12px; margin-bottom:10px;"></div>
    <button class="btn btn-primary" id="loginBtn" onclick="handleLogin()">دخول</button>
    <div class="back-link" onclick="document.getElementById('demoNote').style.display='block'">تجربة بدون حساب (وضع العرض) ←</div>
    <div id="demoNote" style="display:none; font-size:11px; color:var(--ink-soft); margin-top:10px; text-align:center;">
      وضع العرض يعرض بيانات تجريبية دون ربط حقيقي —
      <span style="color:var(--teal-800); cursor:pointer; font-weight:700;" onclick="enterApp('pharmacy', true)">صيدلية تجريبية</span> ·
      <span style="color:var(--teal-800); cursor:pointer; font-weight:700;" onclick="enterApp('admin', true)">مورّد تجريبي</span>
    </div>
  </div>
</div>

<!-- APP SHELL -->
<div id="appShell" class="shell" style="display:none">
  <nav class="nav">
    <div class="nav-brand">
      <div class="mark">ص</div>
      <h1>منصة الصيدليات</h1>
      <p id="brandSub">حساب صيدلية النور</p>
    </div>

    <div id="pharmacyNav">
      <div class="nav-mode">حساب الصيدلية</div>
      <div class="nav-items">
        <button class="nav-item active" data-screen="dashboard"><span class="ico"></span>لوحة الرئيسية</button>
        <button class="nav-item" data-screen="products"><span class="ico"></span>تصفح المنتجات</button>
        <button class="nav-item" data-screen="cart"><span class="ico"></span>السلة والطلب</button>
        <button class="nav-item" data-screen="favorites"><span class="ico"></span>المفضلة وإعادة الطلب</button>
        <button class="nav-item" data-screen="statement"><span class="ico"></span>كشف الحساب</button>
        <button class="nav-item" data-screen="notifications"><span class="ico"></span>الإشعارات</button>
      </div>
    </div>

    <div id="adminNav" style="display:none">
      <div class="nav-mode">لوحة المورّد</div>
      <div class="nav-items">
        <button class="nav-item active" data-screen="admin-overview"><span class="ico"></span>لوحة التحكم</button>
        <button class="nav-item" data-screen="admin-orders"><span class="ico"></span>الطلبات</button>
        <button class="nav-item" data-screen="admin-inventory"><span class="ico"></span>المنتجات</button>
        <button class="nav-item" data-screen="admin-invoices"><span class="ico"></span>الفواتير</button>
        <button class="nav-item" data-screen="admin-reports"><span class="ico"></span>التقارير</button>
        <button class="nav-item" data-screen="notifications"><span class="ico"></span>سجل الإشعارات</button>
      </div>
    </div>

    <div class="nav-foot">تسجيل الخروج</div>
  </nav>

  <div class="main">
    <div class="topbar">
      <h2 id="topbarTitle">لوحة الرئيسية</h2>
      <div class="who"><div class="avatar">ن</div> صيدلية النور</div>
    </div>

    <div class="content">

      <!-- Pharmacy Dashboard -->
      <div class="screen active" id="screen-dashboard">
        <div class="grid g4" style="margin-bottom:20px;">
          <div class="card"><div class="stat-label">الرصيد الآجل</div><div class="stat-value num">42,500</div><div class="stat-sub warn">سقف الائتمان: 100,000 ج.س</div></div>
          <div class="card"><div class="stat-label">طلبات هذا الشهر</div><div class="stat-value num">14</div><div class="stat-sub">+3 عن الشهر الماضي</div></div>
          <div class="card"><div class="stat-label">طلبات قيد المراجعة</div><div class="stat-value num">2</div></div>
          <div class="card"><div class="stat-label">أصناف تقترب من النفاذ</div><div class="stat-value num">5</div><div class="stat-sub warn">راجع التنبيهات</div></div>
        </div>
        <div class="card">
          <h3 class="section-title">آخر الطلبات</h3>
          <table>
            <tr><th>رقم الطلب</th><th>التاريخ</th><th>القيمة</th><th>طريقة الدفع</th><th>الحالة</th></tr>
            <tr><td class="num">#1042</td><td class="num">2026/07/10</td><td class="num">6,200 ج.س</td><td>حساب آجل</td><td><span class="pill ok">تم التسليم</span></td></tr>
            <tr><td class="num">#1041</td><td class="num">2026/07/08</td><td class="num">3,150 ج.س</td><td>تحويل بنكي</td><td><span class="pill pending">قيد المراجعة</span></td></tr>
            <tr><td class="num">#1039</td><td class="num">2026/07/03</td><td class="num">9,800 ج.س</td><td>كاش عند الاستلام</td><td><span class="pill ok">تم التسليم</span></td></tr>
          </table>
        </div>
      </div>

      <!-- Products -->
      <div class="screen" id="screen-products">
        <div class="toolbar">
          <input type="text" id="productSearch" placeholder="ابحث بالاسم التجاري أو المادة الفعالة..." oninput="renderProducts()">
          <select id="productCategoryFilter" onchange="renderProducts()"><option value="">كل التصنيفات</option></select>
        </div>
        <div id="dbStatusBanner" style="display:none; background:#FBF0DA; color:#96701C; font-size:12px; padding:10px 14px; border-radius:9px; margin-bottom:14px;"></div>
        <div class="p-grid" id="productsGrid">
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">بنادول إكسترا</div><div class="p-sub">باراسيتامول 500mg</div></div></div>
            <div class="p-exp" style="color:var(--ok)">صلاحية: 2027/09</div>
            <div class="p-bottom"><div class="p-price num">2,400 ج.س</div><button class="add-btn">+</button></div>
          </div>
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">أوجمنتين</div><div class="p-sub">أموكسيسيلين 1g</div></div></div>
            <div class="p-exp" style="color:var(--danger)">صلاحية: 2026/10 — قريبة</div>
            <div class="p-bottom"><div class="p-price num">5,100 ج.س</div><button class="add-btn">+</button></div>
          </div>
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">فيتامين سي فوار</div><div class="p-sub">1000mg — 20 قرص</div></div></div>
            <div class="p-exp" style="color:var(--ok)">صلاحية: 2028/01</div>
            <div class="p-bottom"><div class="p-price num">1,850 ج.س</div><button class="add-btn">+</button></div>
          </div>
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">كمامات طبية</div><div class="p-sub">علبة 50 قطعة</div></div></div>
            <div class="p-exp" style="color:var(--ink-soft)">—</div>
            <div class="p-bottom"><div class="p-price num">3,000 ج.س</div><button class="add-btn">+</button></div>
          </div>
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">فولتارين جل</div><div class="p-sub">ديكلوفيناك 1%</div></div></div>
            <div class="p-exp" style="color:var(--ok)">صلاحية: 2027/04</div>
            <div class="p-bottom"><div class="p-price num">2,900 ج.س</div><button class="add-btn">+</button></div>
          </div>
          <div class="p-card">
            <div class="p-top"><div><div class="p-name">محلول معقم</div><div class="p-sub">500ml</div></div></div>
            <div class="p-exp" style="color:var(--ok)">صلاحية: 2027/12</div>
            <div class="p-bottom"><div class="p-price num">1,300 ج.س</div><button class="add-btn">+</button></div>
          </div>
        </div>
      </div>

      <!-- Cart -->
      <div class="screen" id="screen-cart">
        <div class="grid g2">
          <div class="card">
            <h3 class="section-title">عناصر السلة</h3>
            <div class="cart-item">
              <div><div class="cart-name">بنادول إكسترا</div><div class="cart-meta">2,400 ج.س / علبة</div></div>
              <div class="qty"><button>−</button><span class="num">10</span><button>+</button></div>
            </div>
            <div class="cart-item">
              <div><div class="cart-name">أوجمنتين</div><div class="cart-meta">5,100 ج.س / علبة</div></div>
              <div class="qty"><button>−</button><span class="num">4</span><button>+</button></div>
            </div>
            <div class="cart-item">
              <div><div class="cart-name">فيتامين سي فوار</div><div class="cart-meta">1,850 ج.س / علبة</div></div>
              <div class="qty"><button>−</button><span class="num">6</span><button>+</button></div>
            </div>
          </div>

          <div class="card">
            <h3 class="section-title">طريقة الدفع</h3>
            <div class="pay-opt">
              <label><input type="radio" name="pay" checked><span>كاش</span></label>
              <label><input type="radio" name="pay"><span>تحويل بنكي</span></label>
              <label><input type="radio" name="pay"><span>حساب آجل</span></label>
            </div>
            <div class="summary-row"><span>عدد الأصناف</span><span class="num">3</span></div>
            <div class="summary-row"><span>الإجمالي الفرعي</span><span class="num">54,600 ج.س</span></div>
            <div class="summary-row total"><span>الإجمالي</span><span class="num">54,600 ج.س</span></div>
            <button class="btn btn-amber" id="confirmOrderBtn" style="width:100%; margin-top:16px; padding:12px;" onclick="confirmOrder()">تأكيد الطلب</button>
          </div>
        </div>
      </div>

      <!-- Favorites -->
      <div class="screen" id="screen-favorites">
        <div class="card" style="margin-bottom:16px;">
          <h3 class="section-title">الأصناف المفضلة</h3>
          <div class="p-grid">
            <div class="p-card">
              <div class="p-top"><div><div class="p-name">بنادول إكسترا</div><div class="p-sub">متوسط الطلب شهريًا: 15 علبة</div></div></div>
              <div class="p-bottom"><div class="p-price num">2,400 ج.س</div><button class="add-btn">+</button></div>
            </div>
