<script>
// ============================================================
// إعدادات الاتصال بـ Supabase — عوّض القيمتين دول ببيانات مشروعك
// (Supabase Dashboard → Project Settings → API)
// ============================================================
const SUPABASE_URL = 'https://iropqrxvrqgttmnkgfle.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_4Q6Wh5cYBnrG7jarWJNhtQ_DSWaZyw8';

let supabaseClient = null;
let isDbConnected = false;
try {
  if (SUPABASE_URL.includes('YOUR-PROJECT') === false) {
    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    isDbConnected = true;
  }
} catch (e) { console.warn('Supabase init failed', e); }

let currentMode = null;
let currentPharmacy = null; // صف الصيدلية من جدول pharmacies بعد الدخول
let allProducts = [];       // تُملأ من قاعدة البيانات أو تبقى فاضية في وضع العرض
let allCategories = [];

// ------------------------------------------------------------
// تسجيل الدخول
// ------------------------------------------------------------
async function handleLogin(){
  const email = document.getElementById('loginEmail').value.trim();
  const password = document.getElementById('loginPassword').value;
  const errBox = document.getElementById('loginError');
  errBox.style.display = 'none';

  if(!supabaseClient){
    errBox.textContent = 'لم يتم ربط قاعدة البيانات بعد. عوّض SUPABASE_URL و SUPABASE_ANON_KEY في الكود، أو جرّب "وضع العرض" بالأسفل.';
    errBox.style.display = 'block';
    return;
  }
  if(!email || !password){
    errBox.textContent = 'أدخل البريد الإلكتروني وكلمة المرور';
    errBox.style.display = 'block';
    return;
  }

  const btn = document.getElementById('loginBtn');
  btn.textContent = 'جارٍ الدخول...'; btn.disabled = true;

  const { data, error } = await supabaseClient.auth.signInWithPassword({ email, password });
  btn.textContent = 'دخول'; btn.disabled = false;

  if(error){
    errBox.textContent = 'بيانات الدخول غير صحيحة: ' + error.message;
    errBox.style.display = 'block';
    return;
  }

  // تحقق هل الحساب صيدلية أو إدارة
  const { data: pharmacy } = await supabaseClient.from('pharmacies').select('*').eq('auth_user_id', data.user.id).maybeSingle();
  if(pharmacy){
    currentPharmacy = pharmacy;
    enterApp('pharmacy', false);
    return;
  }
  const { data: admin } = await supabaseClient.from('admins').select('*').eq('auth_user_id', data.user.id).maybeSingle();
  if(admin){
    enterApp('admin', false);
    return;
  }
  errBox.textContent = 'هذا الحساب غير مربوط بصيدلية أو بحساب إدارة. تحقق من جداول pharmacies / admins.';
  errBox.style.display = 'block';
}

// ------------------------------------------------------------
// الدخول للتطبيق (وضع حقيقي متصل بقاعدة البيانات أو وضع عرض تجريبي)
// ------------------------------------------------------------
function enterApp(mode, isDemo){
  currentMode = mode;
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('appShell').style.display = 'flex';
  document.getElementById('pharmacyNav').style.display = mode === 'pharmacy' ? 'block' : 'none';
  document.getElementById('adminNav').style.display = mode === 'admin' ? 'block' : 'none';

  const pharmacyName = currentPharmacy ? currentPharmacy.name : 'صيدلية النور (عرض)';
  document.getElementById('brandSub').textContent = mode === 'pharmacy' ? 'حساب ' + pharmacyName : 'حساب المورّد';
  document.querySelector('.who').innerHTML = mode === 'pharmacy'
    ? '<div class="avatar">' + pharmacyName.charAt(0) + '</div> ' + pharmacyName
    : '<div class="avatar">م</div> إدارة المورّد';

  const banner = document.getElementById('dbStatusBanner');
  if(!isDbConnected || isDemo){
    banner.style.display = 'block';
    banner.textContent = isDbConnected
      ? 'وضع عرض تجريبي — البيانات المعروضة تجريبية وليست من قاعدة البيانات.'
      : 'قاعدة البيانات غير مربوطة بعد — عوّض SUPABASE_URL في الكود لعرض بيانات حقيقية.';
  } else {
    banner.style.display = 'none';
    loadCategories();
    loadProducts();
  }

  const first = mode === 'pharmacy' ? 'dashboard' : 'admin-overview';
  showScreen(first, mode);
}

function showScreen(name, mode){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  const scope = mode === 'admin' ? '#adminNav' : '#pharmacyNav';
  document.querySelectorAll(scope + ' .nav-item').forEach(b => {
    b.classList.toggle('active', b.dataset.screen === name);
  });
  document.getElementById('topbarTitle').textContent = document.querySelector(scope + ` .nav-item[data-screen="${name}"]`).textContent.trim();
}

document.querySelectorAll('.nav-item').forEach(btn => {
  btn.addEventListener('click', () => {
    const mode = btn.closest('#adminNav') ? 'admin' : 'pharmacy';
    showScreen(btn.dataset.screen, mode);
  });
});

// ------------------------------------------------------------
// تحميل المنتجات والتصنيفات من قاعدة البيانات
// ------------------------------------------------------------
async function loadCategories(){
  if(!supabaseClient) return;
  const { data, error } = await supabaseClient.from('categories').select('*').order('name');
  if(error){ console.error(error); return; }
  allCategories = data || [];
  const filter = document.getElementById('productCategoryFilter');
  const pCategory = document.getElementById('pCategory');
  filter.innerHTML = '<option value="">كل التصنيفات</option>' + allCategories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
  pCategory.innerHTML = allCategories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
}

async function loadProducts(){
  if(!supabaseClient) return;
  const { data, error } = await supabaseClient.from('products').select('*, categories(name)').order('created_at', { ascending: false });
  if(error){ console.error(error); return; }
  allProducts = data || [];
  renderProducts();
  renderInventoryTable();
}

function renderProducts(){
  const grid = document.getElementById('productsGrid');
  const search = (document.getElementById('productSearch')?.value || '').trim();
  const catFilter = document.getElementById('productCategoryFilter')?.value || '';
  const filtered = allProducts.filter(p =>
    (!search || p.name.includes(search)) && (!catFilter || p.category_id === catFilter)
  );
  if(filtered.length === 0){ grid.innerHTML = '<p style="color:var(--ink-soft); font-size:13px;">لا توجد منتجات مطابقة.</p>'; return; }
  grid.innerHTML = filtered.map(p => `
    <div class="p-card">
      <div class="p-top"><div><div class="p-name">${p.name}</div><div class="p-sub">${p.categories ? p.categories.name : ''}</div></div></div>
      <div class="p-exp" style="color:${expiryColor(p.expiry_date)}">${p.expiry_date ? 'صلاحية: ' + p.expiry_date : '—'}</div>
      <div class="p-bottom"><div class="p-price num">${Number(p.price).toLocaleString()} ج.س</div><button class="add-btn" onclick="addToCart('${p.id}')">+</button></div>
    </div>`).join('');
}

function renderInventoryTable(){
  const body = document.getElementById('inventoryTableBody');
  body.innerHTML = allProducts.map(p => `
    <tr>
      <td><div class="prod-thumb">${p.image_url ? `<img src="${p.image_url}">` : '💊'}</div></td>
      <td>${p.name}</td>
      <td>${p.categories ? p.categories.name : ''}</td>
      <td class="num">${p.quantity}</td>
      <td class="num">${Number(p.price).toLocaleString()} ج.س</td>
      <td class="num">${p.expiry_date || '—'}</td>
      <td>${p.quantity <= 10 ? '<span class="pill pending">كمية منخفضة</span>' : '<span class="pill ok">متوفر</span>'}</td>
      <td><button class="btn btn-ghost" style="padding:5px 12px;" onclick="openProductModal('${p.id}')">تعديل</button></td>
    </tr>`).join('');
}

function expiryColor(date){
  if(!date) return 'var(--ink-soft)';
  const monthsLeft = (new Date(date) - new Date()) / (1000*60*60*24*30);
  return monthsLeft < 3 ? 'var(--danger)' : 'var(--ok)';
}

function addToCart(productId){
  alert('تمت إضافة المنتج للسلة (اربط هذه الدالة بحالة سلة حقيقية في التنفيذ النهائي).');
}

// ------------------------------------------------------------
// إضافة / تعديل منتج (مع رفع الصورة إلى Supabase Storage)
// ------------------------------------------------------------
let editingProductId = null;

function openProductModal(productId){
  editingProductId = productId || null;
  document.getElementById('productModal').classList.add('open');
  document.querySelector('#productModal .modal-head h3').textContent = productId ? 'تعديل منتج' : 'إضافة منتج جديد';

  if(productId && allProducts.length){
    const p = allProducts.find(x => x.id === productId);
    if(p){
      document.getElementById('pName').value = p.name;
      document.getElementById('pCategory').value = p.category_id || '';
      document.getElementById('pQuantity').value = p.quantity;
      document.getElementById('pPrice').value = p.price;
      document.getElementById('pExpiry').value = p.expiry_date || '';
      if(p.image_url){
        document.getElementById('imgPreview').src = p.image_url;
        document.getElementById('imgPreview').style.display = 'block';
        document.getElementById('imgPlaceholder').style.display = 'none';
      }
    }
  }
}
function closeProductModal(){
  editingProductId = null;
  document.getElementById('productModal').classList.remove('open');
  document.getElementById('imgInput').value = '';
  document.getElementById('imgPreview').style.display = 'none';
  document.getElementById('imgPlaceholder').style.display = 'block';
  document.getElementById('modalError').style.display = 'none';
  ['pName','pQuantity','pPrice','pExpiry'].forEach(id => document.getElementById(id).value = '');
}
function previewImage(event){
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    const preview = document.getElementById('imgPreview');
    preview.src = e.target.result;
    preview.style.display = 'block';
    document.getElementById('imgPlaceholder').style.display = 'none';
  };
  reader.readAsDataURL(file);
}
document.getElementById('productModal').addEventListener('click', function(e){
  if(e.target === this) closeProductModal();
});

async function saveProduct(){
  const errBox = document.getElementById('modalError');
  errBox.style.display = 'none';
  const name = document.getElementById('pName').value.trim();
  const categoryId = document.getElementById('pCategory').value;
  const quantity = Number(document.getElementById('pQuantity').value) || 0;
  const price = Number(document.getElementById('pPrice').value) || 0;
  const expiry = document.getElementById('pExpiry').value || null;

  if(!name){ errBox.textContent = 'اسم المنتج مطلوب'; errBox.style.display = 'block'; return; }
  if(!supabaseClient){ errBox.textContent = 'قاعدة البيانات غير مربوطة — عوّض بيانات الاتصال في الكود.'; errBox.style.display = 'block'; return; }

  const btn = document.getElementById('saveProductBtn');
  btn.textContent = 'جارٍ الحفظ...'; btn.disabled = true;

  try{
    let imageUrl = null;
    const file = document.getElementById('imgInput').files[0];
    if(file){
      const path = `products/${Date.now()}-${file.name}`;
      const { error: upErr } = await supabaseClient.storage.from('product-images').upload(path, file);
      if(upErr) throw upErr;
      const { data: pub } = supabaseClient.storage.from('product-images').getPublicUrl(path);
      imageUrl = pub.publicUrl;
    }

    const payload = { name, category_id: categoryId || null, quantity, price, expiry_date: expiry };
    if(imageUrl) payload.image_url = imageUrl;

    let error;
    if(editingProductId){
      ({ error } = await supabaseClient.from('products').update(payload).eq('id', editingProductId));
    } else {
      ({ error } = await supabaseClient.from('products').insert(payload));
    }
    if(error) throw error;

    closeProductModal();
    await loadProducts();
  } catch(e){
    errBox.textContent = 'خطأ أثناء الحفظ: ' + e.message;
    errBox.style.display = 'block';
  } finally {
    btn.textContent = 'حفظ المنتج'; btn.disabled = false;
  }
}

// ------------------------------------------------------------
// تأكيد الطلب — إنشاء صف في orders + order_items
// (مبسّطة: تفترض عربة عرض توضيحية؛ اربطها بحالة سلة حقيقية عند التنفيذ)
// ------------------------------------------------------------
async function confirmOrder(){
  if(!supabase || !currentPharmacy){
    alert('تأكيد الطلب يتطلب اتصالًا حقيقيًا بقاعدة البيانات وتسجيل دخول كصيدلية.');
    return;
  }
  const paymentMethod = document.querySelector('input[name="pay"]:checked')?.parentElement.textContent.trim();
  const methodMap = { 'كاش': 'cash', 'تحويل بنكي': 'bank_transfer', 'حساب آجل': 'credit' };

  const btn = document.getElementById('confirmOrderBtn');
  btn.textContent = 'جارٍ الإرسال...'; btn.disabled = true;
  try{
    const { data: order, error } = await supabaseClient.from('orders').insert({
      pharmacy_id: currentPharmacy.id,
      payment_method: methodMap[paymentMethod] || 'cash',
      status: 'pending',
      total: 0 // اربطها بإجمالي السلة الحقيقي
    }).select().single();
    if(error) throw error;
    alert('تم إرسال الطلب رقم ' + order.id);
  } catch(e){
    alert('تعذر إرسال الطلب: ' + e.message);
  } finally {
    btn.textContent = 'تأكيد الطلب'; btn.disabled = false;
  }
}
</script>

